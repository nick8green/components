{
  "name": "@nick8green/components",
  "version": "2.6.1",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "style": "dist/index.css",
  "files": [
    "dist/**",
    "!dist/**/*.test.*",
    "!dist/**/*.stories.*"
  ],
  "scripts": {
    "audit": "yarn npm audit",
    "build": "tsc -p tsconfig.prod.json && vite build",
    "build:storybook": "storybook build --output-dir storybook",
    "clean": "rm -rf dist",
    "format": "prettier --write --parser typescript '**/*.{js,ts,tsx}'",
    "lint": "eslint .",
    "lint:fix": "yarn lint --fix",
    "prebuild": "yarn clean",
    "prepare": "husky && yarn run build",
    "storybook": "storybook dev -p 6006",
    "test": "vitest run --coverage",
    "test:coverage": "vitest run --coverage && open coverage/index.html",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "keywords": [
    "components",
    "react",
    "storybook"
  ],
  "author": "Nick Green <nick-green@live.co.uk> (https://www.nick8green.co.uk/)",
  "license": "MIT",
  "description": "Library of reusable React components.",
  "dependencies": {
    "@fortawesome/fontawesome-common-types": "7.2.0",
    "@fortawesome/fontawesome-svg-core": "7.2.0",
    "@fortawesome/free-brands-svg-icons": "7.2.0",
    "@fortawesome/free-regular-svg-icons": "7.2.0",
    "@fortawesome/free-solid-svg-icons": "7.2.0",
    "@fortawesome/react-fontawesome": "3.3.1",
    "moment": "2.30.1",
    "qrcode.react": "4.2.0",
    "react-markdown": "10.1.0",
    "rehype-react": "8.0.0",
    "remark-gfm": "4.0.1"
  },
  "devDependencies": {
    "@nick8green/formatting": "0.4.0-unique-octopus",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.8",
    "@storybook/addon-docs": "10.4.1",
    "@storybook/addon-essentials": "9.0.0-alpha.12",
    "@storybook/addon-links": "10.4.1",
    "@storybook/addon-onboarding": "10.4.1",
    "@storybook/nextjs-vite": "10.4.1",
    "@storybook/react-vite": "10.4.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.7",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "10.4.0",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.5",
    "next": "16.2.6",
    "prettier": "3.8.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "semantic-release": "25.0.3",
    "storybook": "10.4.1",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vite-plugin-dts": "5.0.1",
    "vitest": "4.1.7"
  },
  "peerDependencies": {
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npm run format",
      "npm run lint",
      "npm run test"
    ]
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "homepage": "http://nick8green.github.io/components",
  "repository": {
    "directory": "packages/components",
    "type": "git",
    "url": "git+https://github.com/nick8green/components.git"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "sideEffects": [
    "*.css"
  ],
  "packageManager": "yarn@4.1.1",
  "resolutions": {
    "fast-uri": ">=3.1.2",
    "ip-address": ">=10.1.1",
    "lodash": " >=4.18.0",
    "postcss": ">=8.5.10",
    "tmp": ">=0.2.4",
    "@nick8green/formatting": "0.5.0"
  },
  "type": "module"
}
