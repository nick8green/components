{
  "name": "@nick8green/components",
  "version": "2.6.1",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "style": "dist/index.css",
  "files": [
    "dist/**",
    "!dist/**/*.test.*",
    "!dist/**/*.stories.*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.prod.json && vite build",
    "build:storybook": "storybook build --output-dir storybook",
    "clean": "rm -rf dist",
    "format": "prettier --write --parser typescript '**/*.{js,ts,tsx}'",
    "lint": "eslint .",
    "lint:fix": "yarn lint --fix",
    "prebuild": "yarn clean",
    "prepare": "husky && yarn run build",
    "storybook": "storybook dev -p 6006",
    "test": "vitest run --coverage",
    "test:coverage": "vitest run --coverage && open coverage/index.html",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "keywords": [
    "components",
    "react",
    "storybook"
  ],
  "author": "Nick Green <nick-green@live.co.uk> (https://www.nick8green.co.uk/)",
  "license": "MIT",
  "description": "Library of reusable React components.",
  "dependencies": {
    "@fortawesome/fontawesome-common-types": "7.2.0",
    "@fortawesome/fontawesome-svg-core": "7.2.0",
    "@fortawesome/free-brands-svg-icons": "7.2.0",
    "@fortawesome/free-regular-svg-icons": "7.2.0",
    "@fortawesome/free-solid-svg-icons": "7.2.0",
    "@fortawesome/react-fontawesome": "3.2.0",
    "moment": "2.30.1",
    "qrcode.react": "4.2.0",
    "react-markdown": "10.1.0",
    "rehype-react": "8.0.0",
    "remark-gfm": "4.0.1"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.2",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.6",
    "@storybook/addon-docs": "10.2.14",
    "@storybook/addon-essentials": "9.0.0-alpha.12",
    "@storybook/addon-links": "10.2.14",
    "@storybook/addon-onboarding": "10.2.14",
    "@storybook/nextjs-vite": "10.2.14",
    "@storybook/react-vite": "10.2.14",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.3.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-v8": "4.0.18",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "10.0.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-storybook": "10.2.14",
    "husky": "9.1.7",
    "jsdom": "28.1.0",
    "lint-staged": "16.3.1",
    "next": "16.1.6",
    "prettier": "3.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "semantic-release": "25.0.3",
    "storybook": "10.2.14",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-plugin-dts": "4.5.4",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.0.18"
  },
  "peerDependencies": {
    "next": "16.0.7",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npm run format",
      "npm run lint",
      "npm run test"
    ]
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "homepage": "http://nick8green.github.io/components",
  "repository": {
    "directory": "packages/components",
    "type": "git",
    "url": "git+https://github.com/nick8green/components.git"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "sideEffects": [
    "*.css"
  ],
  "packageManager": "yarn@1.22.22",
  "resolutions": {
    "glob": "^13.0.0",
    "js-yaml": "^4.1.1",
    "mdast-util-to-hast": "^13.2.1",
    "tar": "^7.5.2",
    "tmp": "^0.2.4"
  }
}
